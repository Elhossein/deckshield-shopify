<!-- ══ FLAME SHIELD HEADER ══ -->
<div class="ds-announce">
  <a href="/products/grill-mat" class="ds-announce-link">🔥 Free Shipping on All Orders &nbsp;·&nbsp; 30-Day Money-Back Guarantee &nbsp;<strong>Shop Now →</strong></a>
</div>

<header class="ds-header">
  <div class="ds-header-inner">
    <nav class="ds-nav">
      <a href="/pages/track-order" class="ds-nav-link">Track Order</a>
      <a href="/pages/contact" class="ds-nav-link">Contact</a>
    </nav>
    <a href="/" class="ds-logo-link" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="ds-logo-img" />
      {%- else -%}
        <div class="fs-logo">
          <div class="fs-logo-wordmark">
            <span class="fs-logo-word">FLAME</span>
            <span class="fs-logo-sep"></span>
            <span class="fs-logo-word">SH</span>
            <span class="fs-logo-i-wrap">
              <svg class="fs-logo-flame" viewBox="0 0 24 30" fill="#111"><path d="M12 0c0 0-2.8 3.6-4.8 7.8C5.2 12 4 15.6 4 18.2c0 4.4 3.6 8 8 8s8-3.6 8-8c0-2.6-1.2-6.2-3.2-10.4C14.8 3.6 12 0 12 0zm0 23.2c-2.8 0-5-2.2-5-5 0-1.8 0.8-4.4 2.2-7.2 0.8-1.6 1.8-3.2 2.8-4.6 1 1.4 2 3 2.8 4.6 1.4 2.8 2.2 5.4 2.2 7.2 0 2.8-2.2 5-5 5z"/></svg>
              <span class="fs-logo-i-stem">I</span>
            </span>
            <span class="fs-logo-word">ELD</span>
          </div>
          <div class="fs-logo-line"></div>
          <div class="fs-logo-tagline">OUTDOOR PROTECTION GEAR</div>
        </div>
      {%- endif -%}
    </a>
    <div class="ds-header-right">
      <a href="/account" class="ds-icon-btn" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <button class="ds-icon-btn ds-open-cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="22" height="22"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="ds-cart-badge">0</span>
      </button>
    </div>
  </div>
</header>

<style>
.ds-announce{background:#e85d04;color:#fff;font-size:0.78rem;font-weight:600;padding:10px 16px;text-align:center}
.ds-announce-link{color:#fff;text-decoration:none;letter-spacing:0.01em}
.ds-announce-link:hover{text-decoration:underline}
.ds-header{position:sticky;top:0;z-index:800;background:#fff;border-bottom:1px solid #eee;box-shadow:0 1px 8px rgba(0,0,0,0.06)}
.ds-header-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:78px}
.ds-nav{display:flex;gap:24px;align-items:center}
.ds-nav-link{font-size:0.78rem;font-weight:600;letter-spacing:0.04em;color:#555;text-transform:uppercase;transition:color 0.15s}
.ds-nav-link:hover{color:#e85d04}
.ds-logo-link{display:flex;justify-content:center;align-items:center;text-decoration:none}
.ds-logo-img{height:56px;width:auto;object-fit:contain}
.ds-header-right{display:flex;align-items:center;gap:8px;justify-content:flex-end}
.ds-icon-btn{position:relative;background:none;border:none;color:#333;padding:6px;display:flex;align-items:center;justify-content:center;border-radius:8px;cursor:pointer;transition:color 0.15s,background 0.15s}
.ds-icon-btn:hover{color:#e85d04;background:rgba(232,93,4,0.08)}
.ds-cart-badge{position:absolute;top:0;right:0;background:#e85d04;color:#fff;font-size:0.58rem;font-weight:800;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;transform:translate(4px,-4px);line-height:1}

/* ═══ TEXT LOGO (fallback when no image uploaded) ═══ */
.fs-logo { display:flex; flex-direction:column; align-items:center; gap:0; line-height:1; }
.fs-logo-wordmark { display:flex; align-items:baseline; gap:0; }
.fs-logo-word { font-family:'Arial Black','Inter',-apple-system,sans-serif; font-size:1.7rem; font-weight:900; color:#111; letter-spacing:-0.02em; text-transform:uppercase; line-height:1; }
.fs-logo-sep { width:1px; height:24px; background:#888; margin:0 7px; flex-shrink:0; align-self:center; }
.fs-logo-i-wrap { position:relative; display:inline-flex; flex-direction:column; align-items:center; align-self:baseline; }
.fs-logo-flame { width:16px; height:20px; display:block; margin-bottom:-4px; }
.fs-logo-i-stem { font-family:'Arial Black','Inter',-apple-system,sans-serif; font-size:1.7rem; font-weight:900; color:#111; letter-spacing:-0.02em; text-transform:uppercase; line-height:1; }
.fs-logo-line { width:100%; height:1.5px; background:#111; margin:5px 0 4px; }
.fs-logo-tagline { font-family:'Inter',Arial,sans-serif; font-size:0.5rem; font-weight:400; color:#111; letter-spacing:0.28em; text-transform:uppercase; }

@media(max-width:600px){
  .ds-header-inner{padding:0 16px;height:68px}
  .ds-nav{gap:14px}
  .ds-nav-link{font-size:0.7rem}
  .ds-logo-img{height:44px}
  .fs-logo-word,.fs-logo-i-stem{font-size:1.2rem}
  .fs-logo-sep{height:17px;margin:0 5px}
  .fs-logo-flame{width:12px;height:15px;margin-bottom:-3px}
  .fs-logo-tagline{font-size:0.38rem;letter-spacing:0.2em}
  .fs-logo-line{margin:3px 0 3px}
}
@media(max-width:400px){
  .ds-nav{display:none}
  .ds-header-inner{grid-template-columns:auto 1fr}
}
</style>

<script>
fetch('/cart.js').then(function(r){return r.json();}).then(function(c){
  var b=document.querySelector('.ds-cart-badge');
  if(b)b.textContent=c.item_count||0;
});
</script>

{% schema %}{"name":"Flame Shield Header","settings":[]}{% endschema %}