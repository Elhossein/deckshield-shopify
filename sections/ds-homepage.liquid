<!-- ══ HOMEPAGE HERO ══ -->
<section class="dsh-hero">
  <div class="dsh-hero-inner">
    <div class="dsh-hero-text">
      <p class="dsh-eyebrow">🏆 AMERICA'S #1 GRILL MAT</p>
      <h1 class="dsh-hero-title">Protect Your Deck.<br><span>Grill Without Guilt.</span></h1>
      <p class="dsh-hero-sub">The heavy-duty, weather-proof mat that keeps grease, stains &amp; spills off your deck — forever. Trusted by 50,000+ homeowners across the US.</p>
      <div class="dsh-hero-btns">
        <a href="/products/{{ section.settings.product_handle | default: 'grill-mat' }}" class="dsh-btn-primary">Shop Now →</a>
      </div>
      <div class="dsh-hero-stars">
        <span style="color:#f5a623">★★★★★</span>
        <span>Loved by <strong>50,000+</strong> homeowners across the US</span>
      </div>
    </div>
    <div class="dsh-hero-img-wrap">
      <div class="dsh-bestseller-pill">⭐ Best Seller</div>
      <img src="{{ 'gs-lifestyle-1.jpg' | asset_url }}" alt="DeckShield Grill Mat in use" class="dsh-hero-img" />
    </div>
  </div>
</section>

<!-- ══ TRUST BAR ══ -->
<div class="dsh-trust-bar">
  <div class="dsh-trust-bar-inner">
    <div class="dsh-trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      <div><strong>Free Shipping</strong><span>On every order</span></div>
    </div>
    <div class="dsh-trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      <div><strong>30-Day Guarantee</strong><span>Money back, no questions</span></div>
    </div>
    <div class="dsh-trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      <div><strong>Secure Checkout</strong><span>SSL encrypted &amp; safe</span></div>
    </div>
    <div class="dsh-trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      <div><strong>50,000+ Customers</strong><span>And growing every day</span></div>
    </div>
  </div>
</div>

<!-- ══ FEATURED PRODUCT ══ -->
<section class="dsh-featured">
  <div class="dsh-featured-inner">
    <div class="dsh-featured-img-col">
      <img src="{{ 'gs-main.jpg' | asset_url }}" alt="DeckShield Grill Mat" class="dsh-featured-img" />
    </div>
    <div class="dsh-featured-text">
      <p class="dsh-eyebrow2">FEATURED PRODUCT</p>
      <h2 class="dsh-feat-title">Premium 65" × 36" Deck &amp; Patio Grill Mat</h2>
      <p class="dsh-feat-desc">Stop scrubbing grease off your deck after every cookout. The DeckShield mat sits under your grill and catches everything — grease, ash, drips, and spills. Rinse clean in 30 seconds.</p>
      <ul class="dsh-feat-bullets">
        <li>✅ 100% Weather-Resistant PVC — won't warp or crack</li>
        <li>✅ Fits most grills, smokers &amp; griddles</li>
        <li>✅ Non-slip design stays exactly in place</li>
        <li>✅ Works on wood, composite &amp; concrete</li>
      </ul>
      <a href="/products/{{ section.settings.product_handle | default: 'grill-mat' }}" class="dsh-btn-primary" style="display:inline-flex;align-items:center;gap:8px;margin-top:8px">Shop Now →</a>
    </div>
  </div>
</section>

<!-- ══ TESTIMONIALS ══ -->
<section class="dsh-social">
  <div class="dsh-social-inner">
    <p class="dsh-eyebrow" style="text-align:center">REAL REVIEWS</p>
    <h2 class="dsh-social-title">What Homeowners Are Saying</h2>
    <div class="dsh-reviews-row">
      <div class="dsh-rev-card"><div class="dsh-rev-stars">★★★★★</div><p>"Rinsed clean in 30 seconds. Best outdoor purchase I've made."</p><strong>— Mike D., Austin TX</strong></div>
      <div class="dsh-rev-card"><div class="dsh-rev-stars">★★★★★</div><p>"My deck looks brand new after grilling season. Worth every penny."</p><strong>— Sarah L., Charlotte NC</strong></div>
      <div class="dsh-rev-card"><div class="dsh-rev-stars">★★★★★</div><p>"Stays put, easy to clean, and actually fits my whole grill area."</p><strong>— James R., Denver CO</strong></div>
    </div>
  </div>
</section>

<style>
/* ── Hero ── */
.dsh-hero{background:linear-gradient(135deg,#f8f8f6 0%,#fff5f0 100%);padding:60px 20px 72px}
.dsh-hero-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
@media(max-width:780px){.dsh-hero-inner{grid-template-columns:1fr;gap:40px}}
.dsh-eyebrow{font-size:0.7rem;font-weight:800;letter-spacing:0.14em;color:#e85d04;text-transform:uppercase;margin-bottom:12px}
.dsh-hero-title{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:#111;line-height:1.1;letter-spacing:-0.03em;margin-bottom:20px}
.dsh-hero-title span{color:#e85d04}
.dsh-hero-sub{font-size:1rem;color:#555;line-height:1.7;margin-bottom:28px;max-width:480px}
.dsh-hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:24px}
.dsh-btn-primary{display:inline-flex;align-items:center;padding:16px 32px;background:linear-gradient(135deg,#bf4500,#e85d04);color:#fff;font-weight:800;font-size:1rem;border-radius:12px;box-shadow:0 4px 16px rgba(232,93,4,0.3);transition:transform 0.15s,box-shadow 0.15s;letter-spacing:0.01em}
.dsh-btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(232,93,4,0.4)}
.dsh-btn-secondary{display:inline-flex;align-items:center;padding:16px 32px;background:#fff;color:#111;font-weight:700;font-size:1rem;border-radius:12px;border:2px solid #ddd;transition:border-color 0.15s}
.dsh-btn-secondary:hover{border-color:#e85d04;color:#e85d04}
.dsh-hero-stars{display:flex;align-items:center;gap:10px;font-size:0.85rem;color:#555}
.dsh-hero-img-wrap{position:relative}
.dsh-hero-img{width:100%;border-radius:20px;box-shadow:0 8px 40px rgba(0,0,0,0.12);object-fit:cover}
.dsh-bestseller-pill{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#bf4500,#e85d04);color:#fff;font-size:0.72rem;font-weight:800;padding:8px 20px;border-radius:99px;white-space:nowrap;letter-spacing:0.06em;box-shadow:0 4px 14px rgba(232,93,4,0.35)}

/* ── Trust bar ── */
.dsh-trust-bar{background:#111;padding:32px 20px}
.dsh-trust-bar-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
@media(max-width:780px){.dsh-trust-bar-inner{grid-template-columns:repeat(2,1fr)}}
@media(max-width:420px){.dsh-trust-bar-inner{grid-template-columns:1fr}}
.dsh-trust-item{display:flex;align-items:center;gap:14px;color:#fff}
.dsh-trust-item svg{color:#e85d04;flex-shrink:0}
.dsh-trust-item div{display:flex;flex-direction:column}
.dsh-trust-item strong{font-size:0.9rem;color:#fff}
.dsh-trust-item span{font-size:0.75rem;color:rgba(255,255,255,0.5);margin-top:2px}

/* ── Featured ── */
.dsh-featured{padding:72px 20px;background:#fff}
.dsh-featured-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
@media(max-width:780px){.dsh-featured-inner{grid-template-columns:1fr}}
.dsh-featured-img{width:100%;border-radius:20px;box-shadow:0 4px 24px rgba(0,0,0,0.1)}
.dsh-eyebrow2{font-size:0.68rem;font-weight:800;letter-spacing:0.14em;color:#e85d04;text-transform:uppercase;margin-bottom:10px}
.dsh-feat-title{font-size:clamp(1.5rem,3vw,2rem);font-weight:900;color:#111;letter-spacing:-0.02em;margin-bottom:16px;line-height:1.2}
.dsh-feat-desc{font-size:0.95rem;color:#555;line-height:1.7;margin-bottom:20px}
.dsh-feat-bullets{list-style:none;padding:0;margin:0 0 24px;display:flex;flex-direction:column;gap:10px}
.dsh-feat-bullets li{font-size:0.9rem;color:#333;font-weight:500}

/* ── Social proof ── */
.dsh-social{padding:72px 20px;background:#f8f8f6}
.dsh-social-inner{max-width:1080px;margin:0 auto}
.dsh-social-title{font-size:clamp(1.5rem,3vw,2rem);font-weight:900;color:#111;letter-spacing:-0.02em;margin-bottom:40px;text-align:center}
.dsh-reviews-row{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:640px){.dsh-reviews-row{grid-template-columns:1fr}}
.dsh-rev-card{background:#fff;border-radius:16px;padding:28px 24px;border:1px solid #eee;box-shadow:0 2px 12px rgba(0,0,0,0.04)}
.dsh-rev-stars{color:#f5a623;font-size:1.1rem;letter-spacing:2px;margin-bottom:14px}
.dsh-rev-card p{font-size:0.9rem;color:#444;line-height:1.7;font-style:italic;margin-bottom:14px}
.dsh-rev-card strong{font-size:0.8rem;color:#888}
</style>

{% schema %}
{
  "name": "DeckShield Homepage",
  "settings": [
    {
      "type": "text",
      "id": "product_handle",
      "label": "Product URL handle",
      "info": "Go to your product in Shopify admin and copy the handle from the URL (e.g. 'grill-mat')",
      "default": "grill-mat"
    }
  ]
}
{% endschema %}