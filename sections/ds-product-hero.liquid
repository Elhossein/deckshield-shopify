{%- assign ds = product -%}
{%- assign fv = ds.selected_or_first_available_variant -%}
{%- assign ds_imgs = 'gs-main.jpg,gs-lifestyle-1.jpg,gs-info-1.jpg,gs-info-2.jpg,gs-info-3.jpg,gs-info-4.jpg' | split: ',' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- ══ PRODUCT HERO ══ -->
<section class="fs-hero">
  <div class="fs-hero-wrap">

    <!-- LEFT: Sticky Gallery -->
    <div class="fs-gallery" id="fs-gallery">
      <div class="fs-gallery-main">
        {%- if ds.images.size > 0 -%}
          <img id="fs-main-img" src="{{ ds.featured_image | image_url: width: 1000 }}" alt="{{ ds.title }}" />
        {%- else -%}
          <img id="fs-main-img" src="{{ 'gs-main.jpg' | asset_url }}" alt="{{ ds.title }}" />
        {%- endif -%}
        <span class="fs-badge">🏆 Best Seller</span>
      </div>
      <div class="fs-thumbs">
        {%- if ds.images.size > 0 -%}
          {%- for img in ds.images -%}
            <button class="fs-thumb{% if forloop.first %} active{% endif %}" data-src="{{ img | image_url: width: 1000 }}">
              <img src="{{ img | image_url: width: 120 }}" alt="{{ ds.title }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- for img in ds_imgs -%}
            <button class="fs-thumb{% if forloop.first %} active{% endif %}" data-src="{{ img | asset_url }}">
              <img src="{{ img | asset_url }}" alt="View {{ forloop.index }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT: Product Info -->
    <div class="fs-info">

      <!-- Rating row -->
      <div class="fs-rating-row">
        <span class="fs-stars">★★★★★</span>
        <span class="fs-rating-num">4.8 / 5</span>
        <span class="fs-sep2">·</span>
        <span class="fs-review-link">Loved by <strong>50,000+</strong> customers</span>
      </div>

      <!-- Title -->
      <h1 class="fs-title">{{ ds.title }}</h1>

      <!-- Subtitle -->
      <p class="fs-subtitle">The only grill mat built to last — <strong>weather-proof, non-slip, and spotless in 30 seconds.</strong></p>

      <!-- Price -->
      <div class="fs-price-block">
        <span class="fs-price" id="fs-price">$59.99</span>
        <s class="fs-was" id="fs-was">$79.99</s>
        <span class="fs-save-pill" id="fs-save-pill">SAVE 25%</span>
      </div>
      <p class="fs-shopify-pay">or 4 interest-free payments of <strong id="fs-installment">$15.00</strong> with <strong>Shop Pay</strong></p>

      <!-- ═══ SALE TIMER ═══ -->
      <div class="fs-sale-timer">
        <div class="fs-sale-left">
          <span class="fs-sale-icon">🔥</span>
          <span class="fs-sale-label">Sale ends in:</span>
        </div>
        <div class="fs-timer-boxes">
          <div class="fs-timer-box"><span id="fs-hr">05</span><small>HRS</small></div>
          <span class="fs-timer-sep">:</span>
          <div class="fs-timer-box"><span id="fs-mn">00</span><small>MIN</small></div>
          <span class="fs-timer-sep">:</span>
          <div class="fs-timer-box"><span id="fs-sc">00</span><small>SEC</small></div>
        </div>
      </div>

      <!-- ═══ LOW STOCK URGENCY ═══ -->
      <div class="fs-urgency">
        <div class="fs-urgency-top">
          <span class="fs-urgency-dot"></span>
          <span>Hurry up! Only <strong>2 items</strong> left in stock!</span>
        </div>
        <div class="fs-urgency-bar"><div class="fs-urgency-fill"></div></div>
        <div class="fs-urgency-bottom">
          <span>Almost gone</span>
          <span>93% sold</span>
        </div>
      </div>

      <!-- ═══ BUNDLE DEALS ═══ -->
      <p class="fs-bundle-heading">BUY MORE &amp; SAVE</p>
      <div class="fs-bundles" id="fs-bundles">

        <div class="fs-bundle-card fs-bundle-active" data-qty="1" data-price="5999" data-compare="7999">
          <div class="fs-bundle-radio"><div class="fs-bundle-dot"></div></div>
          <div class="fs-bundle-info">
            <strong>1 Mat</strong>
            <span>🔥 Save $20.00 today!</span>
          </div>
          <div class="fs-bundle-prices">
            <span class="fs-bundle-price">$59.99</span>
            <s class="fs-bundle-compare">$79.99</s>
          </div>
        </div>

        <div class="fs-bundle-card" data-qty="2" data-price="8999" data-compare="11998">
          <div class="fs-bundle-radio"><div class="fs-bundle-dot"></div></div>
          <div class="fs-bundle-info">
            <strong>2 Mats</strong>
            <span>🎉 Buy One Get One <b>Half Off</b></span>
          </div>
          <div class="fs-bundle-prices">
            <span class="fs-bundle-price">$89.99</span>
            <s class="fs-bundle-compare">$119.98</s>
          </div>
        </div>

        <div class="fs-bundle-divider">
          <span class="fs-bundle-best-tag">⭐ BEST VALUE — MOST POPULAR</span>
        </div>

        <div class="fs-bundle-card fs-bundle-best" data-qty="3" data-price="12999" data-compare="17997">
          <div class="fs-bundle-radio"><div class="fs-bundle-dot"></div></div>
          <div class="fs-bundle-info">
            <strong>3 Mats — Family Deal</strong>
            <span>🔥 Perfect for the whole family</span>
          </div>
          <div class="fs-bundle-prices">
            <span class="fs-bundle-price">$129.99</span>
            <s class="fs-bundle-compare">$179.97</s>
          </div>
        </div>

      </div>

      <!-- Variant data -->
      <script id="fs-variant-data" type="application/json">
        [{%- for v in ds.variants -%}{"id":{{ v.id }},"price":{{ v.price }},"compare_at_price":{{ v.compare_at_price | default: 0 }},"available":{{ v.available }}}{% unless forloop.last %},{% endunless %}{%- endfor -%}]
      </script>

      <!-- Bullets -->
      <ul class="fs-bullets">
        <li><svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>100% Weather-Resistant PVC — rain, UV &amp; heat proof all season</span></li>
        <li><svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Shields grease, spills &amp; stains — wood, composite &amp; concrete safe</span></li>
        <li><svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Non-slip design — stays locked in place under any grill</span></li>
        <li><svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Rinse-clean in 30 seconds — just a garden hose</span></li>
      </ul>

      <!-- CTA -->
      <button class="fs-cta" id="fs-cta">
        Add to Cart — <span id="fs-cta-price">$59.99</span>
      </button>

      <!-- Stock bar -->
      <div class="fs-stock-wrap">
        <div class="fs-stock-bar"><div class="fs-stock-fill" style="width:78%"></div></div>
        <p class="fs-stock-text">⚡ <strong>78% SOLD</strong> — Only 12 left at this price</p>
      </div>

      <!-- Guarantee box -->
      <div class="fs-guarantee">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <strong>30-Day Money-Back Guarantee</strong>
          <span>Love your deck, or get a full refund. 100% risk-free.</span>
        </div>
      </div>

      <!-- Trust icons -->
      <div class="fs-trust">
        <div class="fs-trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg><span>Free Shipping</span></div>
        <div class="fs-trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg><span>Secure Checkout</span></div>
        <div class="fs-trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>1-Year Warranty</span></div>
      </div>

      <!-- Collapsibles -->
      <div class="fs-accordions">
        <details class="fs-acc"><summary class="fs-acc-q">What's in the Box <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary><p class="fs-acc-a">1 × Premium Deck &amp; Patio Grill Mat (65" × 36") · 100% weather-resistant PVC · Black diamond-plate finish · Wall peg storage hole.</p></details>
        <details class="fs-acc"><summary class="fs-acc-q">How to Use <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary><p class="fs-acc-a">Unroll and place under your grill. After use, wipe solids and rinse with a garden hose. Dry in minutes. Roll up and hang using the built-in hook hole.</p></details>
        <details class="fs-acc"><summary class="fs-acc-q">Shipping &amp; Returns <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary><p class="fs-acc-a">Free US shipping on all orders. Ships in 1–2 business days, delivers in 3–7 days. 30-day hassle-free returns. We cover return shipping.</p></details>
      </div>

    </div>
  </div>
</section>

<!-- ══ VIDEOS ══ -->
{%- assign vid_idx = 0 -%}
{%- for media in ds.media -%}
  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
    {%- assign vid_idx = vid_idx | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if vid_idx > 0 -%}
<section class="fs-vid-section">
  <div class="fs-vid-inner">
    <p class="fs-eyebrow-dark">SEE IT IN ACTION</p>
    <h2 class="fs-sec-h2" style="margin-bottom:40px">Watch How It Works</h2>

    {%- assign vid_n = 0 -%}
    {%- for media in ds.media -%}
      {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}

        {%- if vid_n == 0 -%}
          <!-- First video: large full-width hero (like Solawave) -->
          <div class="fs-vid-featured">
            {%- if media.media_type == 'video' -%}
              <video controls autoplay muted loop playsinline preload="auto"{% if media.preview_image %} poster="{{ media.preview_image | image_url: width: 1200 }}"{% endif %}>
                {%- for src in media.sources -%}<source src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
              </video>
            {%- elsif media.media_type == 'external_video' and media.host == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1&mute=1&rel=0" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>
            {%- endif -%}
          </div>
          {%- if vid_idx > 1 -%}<div class="fs-vid-row">{%- endif -%}
        {%- else -%}
          <!-- Remaining videos: thumbnail cards in scroll row -->
          <div class="fs-vid-card"
            {%- if media.media_type == 'video' -%}
              {%- for src in media.sources limit: 1 %} data-src="{{ src.url }}" data-mime="{{ src.mime_type }}"{% endfor %}{% if media.preview_image %} data-poster="{{ media.preview_image | image_url: width: 800 }}"{% endif %}
            {%- elsif media.media_type == 'external_video' and media.host == 'youtube' -%}
              data-yt="{{ media.external_id }}"
            {%- endif -%}>
            <div class="fs-vid-thumb">
              {%- if media.preview_image -%}
                <img src="{{ media.preview_image | image_url: width: 400 }}" alt="Video {{ vid_n | plus: 1 }}" loading="lazy">
              {%- else -%}
                <div style="width:100%;height:100%;background:#222"></div>
              {%- endif -%}
              <div class="fs-vid-play"><svg viewBox="0 0 24 24" width="52" height="52"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.6)"/><polygon points="10,8 18,12 10,16" fill="white"/></svg></div>
            </div>
            <p class="fs-vid-label">Video {{ vid_n | plus: 1 }}</p>
          </div>
        {%- endif -%}

        {%- assign vid_n = vid_n | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if vid_idx > 1 -%}</div>{%- endif -%}
  </div>

  <!-- Lightbox -->
  <div class="fs-vid-lb" id="fs-vid-lb" aria-hidden="true">
    <button class="fs-vid-lb-close" id="fs-vid-lb-close" aria-label="Close">✕</button>
    <div class="fs-vid-lb-body" id="fs-vid-lb-body"></div>
  </div>

  <script>
  (function(){
    var lb = document.getElementById('fs-vid-lb');
    var lbBody = document.getElementById('fs-vid-lb-body');
    function openLb(html){ lbBody.innerHTML = html; lb.setAttribute('aria-hidden','false'); document.body.style.overflow = 'hidden'; }
    function closeLb(){ lb.setAttribute('aria-hidden','true'); lbBody.innerHTML = ''; document.body.style.overflow = ''; }
    document.getElementById('fs-vid-lb-close').addEventListener('click', closeLb);
    lb.addEventListener('click', function(e){ if(e.target === lb) closeLb(); });
    document.querySelectorAll('.fs-vid-card').forEach(function(card){
      card.addEventListener('click', function(){
        if(card.dataset.yt){
          openLb('<iframe src="https://www.youtube.com/embed/'+card.dataset.yt+'?autoplay=1&rel=0" frameborder="0" allowfullscreen allow="autoplay;encrypted-media" style="width:100%;aspect-ratio:16/9;border-radius:16px;display:block"></iframe>');
        } else if(card.dataset.src){
          var v = document.createElement('video');
          v.controls = true; v.autoplay = true; v.muted = true; v.setAttribute('playsinline','');
          if(card.dataset.poster) v.poster = card.dataset.poster;
          v.innerHTML = '<source src="'+card.dataset.src+'" type="'+(card.dataset.mime||'video/mp4')+'">';
          openLb(''); lbBody.appendChild(v);
        }
      });
    });
  })();
  </script>
</section>
{%- endif -%}

<!-- ══ SOCIAL PROOF TICKER ══ -->
<div class="fs-ticker">
  <div class="fs-ticker-track">
    {%- for i in (1..8) -%}
      <span>"Best purchase I made this summer!" — <strong>Mike D.</strong></span><span class="fs-tsep">★★★★★</span>
      <span>"My deck looks brand new after grilling season." — <strong>Sarah L.</strong></span><span class="fs-tsep">★★★★★</span>
      <span>"Rinses clean in 30 seconds. Unreal." — <strong>James R.</strong></span><span class="fs-tsep">★★★★★</span>
    {%- endfor -%}
  </div>
</div>

