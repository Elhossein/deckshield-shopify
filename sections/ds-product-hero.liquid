{%- assign ds = product -%}
{%- assign fv = ds.selected_or_first_available_variant -%}
{%- assign ds_imgs = 'gs-main.jpg,gs-lifestyle-1.jpg,gs-info-1.jpg,gs-info-2.jpg,gs-info-3.jpg,gs-info-4.jpg' | split: ',' -%}

<!-- ══ PRODUCT HERO ══ -->
<section class="ds-hero">
  <div class="ds-hero-layout">

    <!-- LEFT: Gallery -->
    <div class="ds-gallery">
      <div class="ds-gallery-main">
        {%- if ds.images.size > 0 -%}
          <img id="ds-main-img" src="{{ ds.featured_image | image_url: width: 900 }}" alt="{{ ds.title }}" class="ds-main-img" />
        {%- else -%}
          <img id="ds-main-img" src="{{ 'gs-main.jpg' | asset_url }}" alt="{{ ds.title }}" class="ds-main-img" />
        {%- endif -%}
        <div class="ds-award-badge">🏆 #1 Best Seller</div>
      </div>
      <div class="ds-thumbs">
        {%- if ds.images.size > 0 -%}
          {%- for img in ds.images -%}
            <button type="button" class="ds-thumb{% if forloop.first %} ds-thumb--active{% endif %}" data-src="{{ img | image_url: width: 900 }}">
              <img src="{{ img | image_url: width: 120 }}" alt="{{ ds.title }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- for img in ds_imgs -%}
            <button type="button" class="ds-thumb{% if forloop.first %} ds-thumb--active{% endif %}" data-src="{{ img | asset_url }}">
              <img src="{{ img | asset_url }}" alt="View {{ forloop.index }}" loading="lazy" />
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- RIGHT: Form -->
    <div class="ds-form">

      <!-- Award row -->
      <div class="ds-awards-row">
        <span class="ds-award-pill">🔥 Outdoor Living Award 2024</span>
        <span class="ds-award-pill">⭐ Amazon's Choice</span>
      </div>

      <!-- Social proof -->
      <div class="ds-proof-badge">
        <span class="ds-pulse"></span>
        <span>🛡️ <strong>50,000+</strong> decks protected — loved by homeowners</span>
      </div>

      <!-- Stars -->
      <div class="ds-stars-row">
        <span class="ds-stars">★★★★★</span>
        <span class="ds-review-ct">4.8 · 3,241 verified reviews</span>
      </div>

      <!-- Title -->
      <h1 class="ds-title">{{ ds.title }}</h1>
      <p class="ds-tagline">The last grill mat you'll ever need. <em>Protect your deck in seconds</em> — weather-proof, non-slip, and effortless to clean.</p>

      <!-- Price -->
      <div class="ds-price-row">
        <span class="ds-price" id="ds-price">{{ fv.price | money }}</span>
        <s class="ds-compare" id="ds-compare"{% unless fv.compare_at_price > fv.price %} style="display:none"{% endunless %}>{{ fv.compare_at_price | money }}</s>
        {%- if fv.compare_at_price > fv.price -%}
          {%- assign save_pct = fv.compare_at_price | minus: fv.price | times: 100 | divided_by: fv.compare_at_price -%}
          <span class="ds-save-badge">SAVE {{ save_pct }}%</span>
        {%- endif -%}
      </div>

      <!-- Installments note -->
      <p class="ds-installment">or 4 interest-free payments of <strong>{{ fv.price | divided_by: 4 | money }}</strong> with <strong>Shop Pay</strong></p>

      <!-- Variant data -->
      <script id="ds-variant-data" type="application/json">
        [{%- for v in ds.variants -%}{"id":{{ v.id }},"price":{{ v.price }},"compare_at_price":{{ v.compare_at_price | default: 0 }},"available":{{ v.available }}}{% unless forloop.last %},{% endunless %}{%- endfor -%}]
      </script>

      <!-- Key bullets -->
      <ul class="ds-bullets">
        <li><span class="ds-bi">🌧️</span> <strong>100% Weather-Resistant PVC</strong> — handles rain, sun & heat all season</li>
        <li><span class="ds-bi">🛡️</span> <strong>Shields grease, spills & stains</strong> — keeps wood, composite & concrete spotless</li>
        <li><span class="ds-bi">🔒</span> <strong>Non-slip & stays in place</strong> — won't shift under your grill or griddle</li>
        <li><span class="ds-bi">💧</span> <strong>Easy clean</strong> — just rinse with a hose and it's good to go</li>
        <li><span class="ds-bi">📐</span> <strong>65" × 36" generous size</strong> — fits most grills, smokers & griddles</li>
      </ul>

      <!-- Trust row -->
      <div class="ds-trust-row">
        <div class="ds-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Free Shipping</span>
        </div>
        <div class="ds-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>30-Day Guarantee</span>
        </div>
        <div class="ds-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span>Secure Checkout</span>
        </div>
        <div class="ds-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>1-Year Warranty</span>
        </div>
      </div>

      <!-- CTA -->
      <button type="button" class="ds-cta-btn" id="ds-cta-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Add to Cart — <span id="ds-cta-price">{{ fv.price | money }}</span>
      </button>

      <p class="ds-ship-note">🚚 Free shipping · Ships in 1–2 business days · Arrives in <strong>3–7 days</strong></p>

      <!-- Urgency -->
      <div class="ds-urgency">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Deal ends in <strong id="ds-timer">11:47:02</strong> — only <strong>12 left</strong> in stock</span>
      </div>

      <!-- Collapsibles -->
      <div class="ds-collapsibles">
        <details class="ds-detail">
          <summary class="ds-det-sum"><span>📦</span> What's in the Box <svg class="ds-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="ds-det-body"><p>1 × Premium Deck &amp; Patio Grill Mat (65" × 36") · Made from 100% weather-resistant PVC · Black finish · Wall peg hole for storage.</p></div>
        </details>
        <details class="ds-detail">
          <summary class="ds-det-sum"><span>⚙️</span> How to Use <svg class="ds-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="ds-det-body"><p>Unroll and place flat beneath your grill, smoker, or griddle. The mat's weight keeps it firmly in place. After grilling, wipe up solids and rinse with a garden hose — dry within minutes. Roll up and store using the built-in hook hole.</p></div>
        </details>
        <details class="ds-detail">
          <summary class="ds-det-sum"><span>🛡️</span> 30-Day Guarantee <svg class="ds-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="ds-det-body"><p>Not satisfied for any reason? Contact us within 30 days and we'll refund you in full — no hassle, no questions. Your deck is covered, and so is your purchase.</p></div>
        </details>
        <details class="ds-detail">
          <summary class="ds-det-sum"><span>🚚</span> Shipping &amp; Delivery <svg class="ds-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg></summary>
          <div class="ds-det-body"><p>Free standard shipping on all US orders. Orders ship in 1–2 business days and arrive in 3–7 days. Tracking provided via email. We ship via USPS, UPS, and FedEx.</p></div>
        </details>
      </div>

    </div>
  </div>
</section>

<!-- ══ PRODUCT VIDEOS ══ -->
{%- assign ds_has_video = false -%}
{%- for media in ds.media -%}
  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
    {%- assign ds_has_video = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if ds_has_video -%}
<section class="ds-video-section">
  <div class="ds-video-inner">
    <p class="ds-eyebrow" style="text-align:center">SEE IT IN ACTION</p>
    <h2 class="ds-section-title" style="text-align:center;color:#fff">Watch How It Works</h2>
    <div class="ds-videos-grid">
      {%- for media in ds.media -%}
        {%- if media.media_type == 'video' -%}
          <div class="ds-video-wrap">
            <video controls autoplay muted loop playsinline preload="auto"
              poster="{{ media.preview_image | image_url: width: 800 }}"
              style="background:#000">
              {%- for source in media.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}" />
              {%- endfor -%}
            </video>
          </div>
        {%- elsif media.media_type == 'external_video' -%}
          <div class="ds-video-wrap">
            {%- if media.host == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=0&rel=0"
                frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen loading="lazy"></iframe>
            {%- elsif media.host == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ media.external_id }}"
                frameborder="0" allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen loading="lazy"></iframe>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ SOCIAL PROOF TICKER ══ -->
<div class="ds-ticker-strip">
  <div class="ds-ticker-track">
    {%- for i in (1..8) -%}
      <span>"Finally — a mat that actually stays put!" — <strong>Mike D.</strong></span>
      <span class="ds-tsep">★★★★★</span>
      <span>"My deck looks brand new after grilling season." — <strong>Sarah L.</strong></span>
      <span class="ds-tsep">★★★★★</span>
      <span>"Rinses clean in 30 seconds. Incredible." — <strong>James R.</strong></span>
      <span class="ds-tsep">★★★★★</span>
    {%- endfor -%}
  </div>
</div>

<!-- ══ WHY US vs COMPETITION (Solawave-style) ══ -->
<section class="ds-vs-section">
  <div class="ds-section-inner">
    <p class="ds-eyebrow">THE DECKSHIELD DIFFERENCE</p>
    <h2 class="ds-section-title">You've seen other grill mats.<br>They aren't DeckShield.</h2>
    <div class="ds-vs-grid">
      <div class="ds-vs-card ds-vs-us">
        <div class="ds-vs-header">DeckShield</div>
        <ul class="ds-vs-list">
          <li class="ds-vs-win">✅ 100% Heavy-Duty PVC — no warping</li>
          <li class="ds-vs-win">✅ 65" × 36" — fits any grill setup</li>
          <li class="ds-vs-win">✅ Non-slip weighted design</li>
          <li class="ds-vs-win">✅ All-weather: rain, UV &amp; heat resistant</li>
          <li class="ds-vs-win">✅ Works on wood, composite &amp; concrete</li>
          <li class="ds-vs-win">✅ Rinse-clean in under 60 seconds</li>
          <li class="ds-vs-win">✅ 30-day money-back guarantee</li>
          <li class="ds-vs-win">✅ 1-Year warranty</li>
        </ul>
      </div>
      <div class="ds-vs-card ds-vs-them">
        <div class="ds-vs-header ds-vs-header--them">Other Brands</div>
        <ul class="ds-vs-list">
          <li class="ds-vs-lose">❌ Thin PVC — cracks &amp; warps in heat</li>
          <li class="ds-vs-lose">❌ Too small — doesn't fit your grill</li>
          <li class="ds-vs-lose">❌ Slides around constantly</li>
          <li class="ds-vs-lose">❌ Fades &amp; cracks after 1 season</li>
          <li class="ds-vs-lose">❌ Only for concrete surfaces</li>
          <li class="ds-vs-lose">❌ Grease soaks in — impossible to clean</li>
          <li class="ds-vs-lose">❌ No returns after use</li>
          <li class="ds-vs-lose">❌ No warranty</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ══ FEATURE HIGHLIGHTS ══ -->
<section class="ds-features">
  <div class="ds-section-inner">
    <p class="ds-eyebrow">BUILT FOR GRILLMASTERS</p>
    <h2 class="ds-section-title">Engineered for Every Backyard</h2>
    <div class="ds-features-grid">
      <div class="ds-feat-card">
        <img src="{{ 'gs-info-1.jpg' | asset_url }}" alt="Weather resistant" class="ds-feat-img" loading="lazy" />
        <div class="ds-feat-content">
          <h3>🌧️ All-Season Durability</h3>
          <p>Made from 100% weather-resistant PVC that withstands rain, intense UV, and high heat — season after season without warping or cracking.</p>
        </div>
      </div>
      <div class="ds-feat-card">
        <img src="{{ 'gs-info-2.jpg' | asset_url }}" alt="Deck protection" class="ds-feat-img" loading="lazy" />
        <div class="ds-feat-content">
          <h3>🛡️ Total Deck Protection</h3>
          <p>Shields wood, composite, and concrete surfaces from grease drips, sauce spills, and coal stains. Your deck stays pristine all BBQ season.</p>
        </div>
      </div>
      <div class="ds-feat-card">
        <img src="{{ 'gs-info-3.jpg' | asset_url }}" alt="Non-slip" class="ds-feat-img" loading="lazy" />
        <div class="ds-feat-content">
          <h3>🔒 Stays Exactly in Place</h3>
          <p>The mat's substantial weight and non-slip surface keep it locked under your grill — no sliding, no shifting, no adjusting mid-cookout.</p>
        </div>
      </div>
      <div class="ds-feat-card">
        <img src="{{ 'gs-info-4.jpg' | asset_url }}" alt="Easy clean" class="ds-feat-img" loading="lazy" />
        <div class="ds-feat-content">
          <h3>💧 30-Second Cleanup</h3>
          <p>Wipe off solids, then blast with a garden hose. Grease and grime rinse away instantly — back to like-new in under a minute.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ HOW IT WORKS ══ -->
<section class="ds-how">
  <div class="ds-section-inner">
    <p class="ds-eyebrow">SIMPLE. EFFECTIVE.</p>
    <h2 class="ds-section-title">Set Up in 3 Seconds. Grill All Season.</h2>
    <div class="ds-steps">
      <div class="ds-step">
        <div class="ds-step-num">01</div>
        <h3 class="ds-step-title">Unroll &amp; Place</h3>
        <p class="ds-step-desc">Simply unroll the mat and position it under your grill. No tools, no installation, no drilling — just place and grill.</p>
      </div>
      <div class="ds-step">
        <div class="ds-step-num">02</div>
        <h3 class="ds-step-title">Grill &amp; Enjoy</h3>
        <p class="ds-step-desc">Fire up the grill and cook with confidence. Grease, drips, and ash land on the mat — not your deck.</p>
      </div>
      <div class="ds-step">
        <div class="ds-step-num">03</div>
        <h3 class="ds-step-title">Rinse &amp; Store</h3>
        <p class="ds-step-desc">Hose it down after grilling — clean in under 60 seconds. Roll up and hang using the built-in storage hole.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ TESTIMONIALS ══ -->
