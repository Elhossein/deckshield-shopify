</section>

<!-- ══ REVIEWS ══ -->
<section class="fs-reviews">
  <div class="fs-sec-inner">

    <!-- Customer photo strip — horizontal scroll like Solawave -->
    <div class="fs-rev-photo-strip">
      {%- if ds.images.size > 0 -%}
        {%- for img in ds.images limit: 8 -%}
          <div class="fs-rev-photo"><img src="{{ img | image_url: width: 300 }}" alt="Customer photo {{ forloop.index }}" loading="lazy" /></div>
        {%- endfor -%}
      {%- else -%}
        {%- assign strip_imgs = 'gs-main.jpg,gs-lifestyle-1.jpg,gs-info-1.jpg,gs-info-2.jpg,gs-info-3.jpg,gs-info-4.jpg' | split: ',' -%}
        {%- for img in strip_imgs -%}
          <div class="fs-rev-photo"><img src="{{ img | asset_url }}" alt="Customer photo {{ forloop.index }}" loading="lazy" /></div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Aggregate rating + star bars -->
    <div class="fs-rev-agg">
      <div class="fs-rev-agg-left">
        <div class="fs-rev-big-score">4.8</div>
        <div class="fs-rev-big-stars">★★★★★</div>
        <p>Based on <strong>3,241</strong> reviews</p>
        <p class="fs-rev-recommend">96% would recommend this product</p>
      </div>
