<script>
(function(){
  var variants = JSON.parse(document.getElementById('fs-variant-data').textContent);
  var v = variants[0];
  var mainImg = document.getElementById('fs-main-img');
  var cta = document.getElementById('fs-cta');
  var stickyBtn = document.getElementById('fs-sticky-btn');
  var ctaPrice = document.getElementById('fs-cta-price');
  var priceEl = document.getElementById('fs-price');
  var wasEl = document.getElementById('fs-was');
  var savePill = document.getElementById('fs-save-pill');
  var stickyPrice = document.getElementById('fs-sticky-price');
  var sticky = document.getElementById('fs-sticky');
  var installmentEl = document.getElementById('fs-installment');

  var bundleQty = 1;

  function fmtCents(c){ return '$'+(c/100).toFixed(2); }

  function updatePriceDisplay(price, compare){
    priceEl.textContent = fmtCents(price);
    wasEl.textContent = fmtCents(compare);
    var pct = Math.round((compare - price) / compare * 100);
    savePill.textContent = 'SAVE ' + pct + '%';
    ctaPrice.textContent = fmtCents(price);
    stickyPrice.textContent = fmtCents(price);
    installmentEl.textContent = fmtCents(Math.round(price / 4));
  }

  // Bundle selection
  document.querySelectorAll('.fs-bundle-card').forEach(function(card){
    card.addEventListener('click', function(){
      document.querySelectorAll('.fs-bundle-card').forEach(function(c){ c.classList.remove('fs-bundle-active'); });
      card.classList.add('fs-bundle-active');
      bundleQty = parseInt(card.dataset.qty);
      updatePriceDisplay(parseInt(card.dataset.price), parseInt(card.dataset.compare));
    });
  });

  // 5-hour countdown timer
  (function(){
    var key = 'fs_sale_end';
    var stored = localStorage.getItem(key);
    var end;
    if(stored && parseInt(stored) > Date.now()){
      end = parseInt(stored);
    } else {
      end = Date.now() + 5*60*60*1000;
      localStorage.setItem(key, end);
    }
    var hrEl = document.getElementById('fs-hr');
    var mnEl = document.getElementById('fs-mn');
    var scEl = document.getElementById('fs-sc');
    function tick(){
      var diff = Math.max(0, Math.floor((end - Date.now()) / 1000));
      var h = Math.floor(diff/3600);
      var m = Math.floor((diff%3600)/60);
      var s = diff%60;
      hrEl.textContent = String(h).padStart(2,'0');
      mnEl.textContent = String(m).padStart(2,'0');
      scEl.textContent = String(s).padStart(2,'0');
    }
    tick();
    setInterval(tick, 1000);
  })();

  // Thumbnails
  document.querySelectorAll('.fs-thumb').forEach(function(t){
    t.addEventListener('click', function(){
      if(mainImg) mainImg.src = t.dataset.src;
      document.querySelectorAll('.fs-thumb').forEach(function(x){ x.classList.remove('active'); });
      t.classList.add('active');
    });
  });

  // Add to cart
  async function addToCart(){
    if(!v){ alert('Product not found. Please refresh.'); return; }
    var orig = cta ? cta.innerHTML : '';
    if(cta){ cta.disabled=true; cta.textContent='Adding…'; }
    if(stickyBtn){ stickyBtn.disabled=true; stickyBtn.textContent='Adding…'; }
    try{
      var res = await fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items:[{id:v.id,quantity:bundleQty}]})});
      if(!res.ok){ var e=await res.json().catch(function(){return{};}); throw new Error(e.description||'Error'); }
      var cart = await fetch('/cart.js').then(function(r){return r.json();});
      var badge = document.querySelector('.ds-cart-badge');
      if(badge) badge.textContent = cart.item_count;
      if(cta){ cta.disabled=false; cta.innerHTML='✓ Added to Cart!'; setTimeout(function(){ cta.innerHTML=orig; },2000); }
      if(stickyBtn){ stickyBtn.disabled=false; stickyBtn.textContent='✓ Added!'; setTimeout(function(){ stickyBtn.textContent='Add to Cart'; },2000); }
      document.querySelector('.ds-open-cart') && document.querySelector('.ds-open-cart').click();
    } catch(err){
      alert('Could not add: '+err.message);
      if(cta){ cta.disabled=false; cta.innerHTML=orig; }
      if(stickyBtn){ stickyBtn.disabled=false; stickyBtn.textContent='Add to Cart'; }
    }
  }
  if(cta) cta.addEventListener('click', addToCart);
  if(stickyBtn) stickyBtn.addEventListener('click', addToCart);

  // Sticky bar
  var hero = document.querySelector('.fs-info');
  if(hero && sticky){
    new IntersectionObserver(function(e){ sticky.style.transform = e[0].isIntersecting ? 'translateY(100%)' : 'translateY(0)'; },{threshold:0.05}).observe(hero);
  }

  // Gallery sticky on scroll
  var gallery = document.getElementById('fs-gallery');
  var info = document.querySelector('.fs-info');
  if(gallery && info && window.innerWidth >= 780){
    gallery.style.position = 'sticky';
    gallery.style.top = '20px';
    gallery.style.alignSelf = 'flex-start';
  }
})();
</script>

